# Database (PostgreSQL)
DATABASE_URL="postgresql://user:password@localhost:5432/fairaudit?schema=public"

# Clerk Authentication (https://clerk.com)
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=pk_test_...
CLERK_SECRET_KEY=sk_test_...
